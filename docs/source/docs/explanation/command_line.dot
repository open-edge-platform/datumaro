digraph command_line {
    splines = polyline;
    rankdir = "LR";
    node [shape = rectangle;];

    datum [shape = box;];

    subgraph cluster_context_free {
        label = "Context-free";

        "convert";
        "detect";
        "compare";
        "dinfo";
        "download";
        "explain";
        "filter";
        "merge";
        "patch";
        "stats";
        "transform";
        "validate";
    }

    subgraph cluster_context {
        label = "Context";
        "util";
    }

    subgraph helper {
        label = "Helper";
        "format";
    }

    subgraph cluster_util {
        label = "Util";
        "split_video";
    }

    "datum" -> {"convert" "detect" "compare" "dinfo" "download" "explain" "filter" "merge" "patch" "stats" "transform" "validate" "format"};
    "util" -> {"split_video"};
}
